Require all granted

<IfModule mod_autoindex.c>
	Options -Indexes
</IfModule>

<IfModule mod_rewrite.c>
	RewriteEngine On

	RewriteRule ^(app|config|db|log|temp|vendor)(/|$) - [F,L]
	RewriteRule ^(composer\.(json|lock)|phinx\.php|package\.json|vite\.config\.ts|readme\.md)$ - [F,L]
	RewriteRule ^www/ - [L]
	RewriteRule ^$ www/ [L]
	RewriteRule (.*) www/$1 [L]
</IfModule>
